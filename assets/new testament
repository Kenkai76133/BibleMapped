<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">

  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <title>New Testament | Bible Mapped</title>

  <meta
    name="description"
    content="A simple, visual New Testament Bible Mapped page centered on infographics, maps, and book-group visuals."
  >

  <link rel="preload" as="image" href="/assets/new-testament/NT-01- New Testament map.png">
  <link rel="preload" as="image" href="/assets/new-testament/NT-02- New Testament books.png">

  <style>
    :root {
      --electric-purple: #7b2cff;
      --ink: #151515;
      --soft-ink: #555555;
      --muted: #777777;
      --line: rgba(21, 21, 21, 0.12);
      --white: #ffffff;
    }

    * {
      box-sizing: border-box;
    }

    html {
      scroll-behavior: smooth;
    }

    body {
      margin: 0;
      background: var(--white);
      color: var(--ink);
      overflow-x: hidden;
    }

    a {
      color: inherit;
      text-decoration: none;
    }

    img {
      max-width: 100%;
      height: auto;
    }

    /* HEADER */

    .site-header {
      width: 100%;
      min-height: 72px;
      padding: 14px 28px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 24px;
      background: rgba(255, 255, 255, 0.94);
      backdrop-filter: blur(12px);
      border-bottom: 1px solid rgba(0, 0, 0, 0.06);
      position: sticky;
      top: 0;
      z-index: 1000;
    }

    .brand {
      display: inline-flex;
      align-items: center;
      min-width: 150px;
    }

    .brand img {
      display: block;
      width: 180px;
      max-height: 52px;
      object-fit: contain;
    }

    .top-nav {
      display: flex;
      align-items: center;
      gap: 22px;
      font-family: Arial, sans-serif;
      font-size: 0.84rem;
      font-weight: 800;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }

    .top-nav a {
      color: #222;
      transition: color 0.2s ease;
    }

    .top-nav a:hover {
      color: var(--electric-purple);
    }

    /* PAGE */

    .nt-page {
      background: #ffffff;
      color: #151515;
      overflow-x: hidden;
    }

    .nt-hero {
      max-width: 980px;
      margin: 0 auto;
      padding: 82px 22px 36px;
      text-align: center;
    }

    .eyebrow {
      font-family: Arial, sans-serif;
      color: var(--electric-purple);
      text-transform: uppercase;
      letter-spacing: 0.16em;
      font-weight: 900;
      font-size: 0.78rem;
      margin: 0 0 14px;
    }

    .nt-hero h1 {
      font-family: Georgia, "Times New Roman", serif;
      font-size: clamp(3.2rem, 8vw, 7rem);
      line-height: 0.92;
      letter-spacing: -0.06em;
      margin: 0 0 22px;
    }

    .nt-hero p,
    .graphic-text p,
    .nt-library p {
      font-family: Arial, sans-serif;
      color: var(--soft-ink);
      line-height: 1.7;
      font-size: 1.08rem;
      margin-left: auto;
      margin-right: auto;
    }

    .nt-hero p {
      max-width: 780px;
    }

    /* MAIN MAP */

    .main-map-section {
      width: 100%;
      padding: 10px 0 76px;
    }

    .flush-map-slot {
      position: relative;
      width: min(92vw, 620px);
      margin: 0 auto;
      background: transparent;
      border: none;
      box-shadow: none;
    }

    .main-infographic {
      display: block;
      width: 100%;
      height: auto;
      border: none;
      box-shadow: none;
      cursor: zoom-in;
    }

    /* CONTEXT SECTION */

    .paired-graphics-section {
      max-width: 1120px;
      margin: 0 auto;
      padding: 70px 22px;
      display: grid;
      grid-template-columns: 0.85fr 1.15fr;
      gap: 42px;
      align-items: center;
    }

    .graphic-text h2,
    .nt-library h2 {
      font-family: Georgia, "Times New Roman", serif;
      font-size: clamp(2.4rem, 5vw, 4.5rem);
      line-height: 0.95;
      letter-spacing: -0.05em;
      margin: 0 0 18px;
    }

    .graphic-text p {
      max-width: 560px;
      margin-left: 0;
    }

    .paired-graphics {
      display: grid;
      place-items: center;
    }

    .floating-graphic {
      display: block;
      width: min(100%, 520px);
      border: none;
      box-shadow: none;
      background: transparent;
      cursor: zoom-in;
    }

    /* LIBRARY */

    .nt-library {
      max-width: 1180px;
      margin: 0 auto;
      padding: 70px 22px 100px;
      text-align: center;
    }

    .library-description {
      max-width: 760px;
      margin-top: 0;
      margin-bottom: 0;
    }

    .infographic-gallery {
      margin-top: 48px;
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 48px 34px;
      align-items: start;
    }

    .floating-item {
      margin: 0;
      background: transparent;
      border: none;
      box-shadow: none;
      transition: transform 0.25s ease;
    }

    .floating-item img {
      display: block;
      width: 100%;
      border: none;
      box-shadow: none;
      cursor: zoom-in;
      background: transparent;
    }

    .floating-item figcaption {
      margin-top: 14px;
      font-family: Arial, sans-serif;
      font-weight: 900;
      color: #222;
      font-size: 0.95rem;
    }

    .tilt-left {
      transform: rotate(-2deg);
    }

    .tilt-right {
      transform: rotate(2deg);
    }

    .floating-item:hover,
    .floating-graphic:hover {
      transform: translateY(-8px) rotate(0deg);
    }

    /* PLACEHOLDER */

    .placeholder-graphic {
      min-height: 420px;
      width: 100%;
      display: grid;
      place-items: center;
      text-align: center;
      background:
        radial-gradient(circle at top, rgba(123, 44, 255, 0.08), transparent 45%),
        #ffffff;
      border: 2px dashed rgba(123, 44, 255, 0.35);
      border-radius: 28px;
      font-family: Arial, sans-serif;
      color: #222;
      padding: 22px;
    }

    .placeholder-graphic span {
      display: block;
      font-size: 1.5rem;
      font-weight: 900;
    }

    .placeholder-graphic small {
      display: block;
      margin-top: 8px;
      color: var(--muted);
      font-weight: 700;
    }

    /* PAN-UP ANIMATION */

    .pan-up {
      opacity: 0;
      transform: translateY(36px);
      transition: opacity 0.75s ease, transform 0.75s ease;
    }

    .pan-up.in-view {
      opacity: 1;
      transform: translateY(0);
    }

    .tilt-left.pan-up.in-view {
      transform: translateY(0) rotate(-2deg);
    }

    .tilt-right.pan-up.in-view {
      transform: translateY(0) rotate(2deg);
    }

    .tilt-left.pan-up.in-view:hover,
    .tilt-right.pan-up.in-view:hover {
      transform: translateY(-8px) rotate(0deg);
    }

    /* FULLSCREEN LIGHTBOX */

    .image-lightbox {
      position: fixed;
      inset: 0;
      z-index: 9999;
      background: #ffffff;
      display: none;
      overflow-y: auto;
      overflow-x: hidden;
      padding: 32px 18px;
      cursor: zoom-out;
      -webkit-overflow-scrolling: touch;
    }

    .image-lightbox.active {
      display: block;
    }

    .image-lightbox img {
      display: block;
      width: min(96vw, 920px);
      max-width: none;
      height: auto;
      margin: 0 auto;
      cursor: zoom-out;
    }

    body.lightbox-open {
      overflow: hidden;
    }

    /* FOOTER */

    .bm-site-footer {
      background: #ffffff;
      border-top: 1px solid rgba(0, 0, 0, 0.08);
      padding: 56px 22px 34px;
      font-family: Arial, sans-serif;
    }

    .bm-site-footer-inner {
      max-width: 1120px;
      margin: 0 auto;
      text-align: center;
    }

    .bm-footer-top {
      display: flex;
      justify-content: center;
      align-items: center;
      gap: 32px;
      flex-wrap: wrap;
      margin-bottom: 28px;
    }

    .bm-footer-wordmark {
      width: 210px;
      max-height: 70px;
      object-fit: contain;
    }

    .bm-footer-social-row {
      display: flex;
      justify-content: center;
      align-items: center;
      gap: 14px;
      flex-wrap: wrap;
    }

    .bm-footer-social-emblem {
      width: 42px;
      height: 42px;
      border-radius: 999px;
      display: inline-flex;
      justify-content: center;
      align-items: center;
      border: 2px solid var(--electric-purple);
      color: var(--electric-purple);
      font-weight: 900;
      font-size: 1.2rem;
      transition: transform 0.2s ease, background 0.2s ease, color 0.2s ease;
    }

    .bm-footer-social-emblem:hover {
      transform: translateY(-3px);
      background: var(--electric-purple);
      color: #ffffff;
    }

    .bm-footer-social-emblem svg {
      width: 22px;
      height: 22px;
      fill: currentColor;
      stroke: currentColor;
      stroke-width: 1.8;
    }

    .instagram-emblem svg {
      fill: none;
    }

    .bm-footer-divider {
      width: min(100%, 760px);
      height: 1px;
      background: rgba(0, 0, 0, 0.12);
      margin: 0 auto 26px;
    }

    .bm-footer-links {
      display: flex;
      justify-content: center;
      align-items: center;
      gap: 10px;
      flex-wrap: wrap;
      margin-bottom: 14px;
      font-size: 0.9rem;
      color: #222;
    }

    .bm-footer-links a {
      color: #222;
      font-weight: 700;
    }

    .bm-footer-links a:hover,
    .bm-footer-heaven-link {
      color: var(--electric-purple);
    }

    .bm-footer-links span {
      color: rgba(0, 0, 0, 0.28);
    }

    .bm-footer-copy {
      color: #777;
      font-size: 0.86rem;
      margin: 24px 0 0;
    }

    /* RESPONSIVE */

    @media (max-width: 900px) {
      .site-header {
        align-items: flex-start;
        flex-direction: column;
        gap: 14px;
      }

      .top-nav {
        width: 100%;
        overflow-x: auto;
        padding-bottom: 4px;
        gap: 16px;
      }

      .paired-graphics-section {
        grid-template-columns: 1fr;
        text-align: center;
      }

      .graphic-text p {
        margin-left: auto;
        margin-right: auto;
      }

      .infographic-gallery {
        grid-template-columns: repeat(2, 1fr);
      }
    }

    @media (max-width: 700px) {
      .image-lightbox {
        padding: 0;
      }

      .image-lightbox img {
        width: 100vw;
        max-width: none;
        height: auto;
        margin: 0;
        display: block;
      }

      body.lightbox-open {
        overflow: hidden;
        touch-action: none;
      }

      .image-lightbox.active {
        overflow-y: auto;
        overflow-x: hidden;
      }
    }

    @media (max-width: 560px) {
      .site-header {
        padding: 14px 18px;
      }

      .brand img {
        width: 160px;
      }

      .top-nav {
        font-size: 0.75rem;
      }

      .nt-hero {
        padding: 54px 18px 20px;
      }

      .nt-hero h1 {
        font-size: clamp(3rem, 15vw, 4.4rem);
      }

      .flush-map-slot {
        width: 100%;
      }

      .paired-graphics-section,
      .nt-library {
        padding-left: 18px;
        padding-right: 18px;
      }

      .infographic-gallery {
        grid-template-columns: 1fr;
        gap: 46px;
      }

      .placeholder-graphic {
        min-height: 340px;
      }

      .bm-footer-top {
        flex-direction: column;
      }

      .bm-footer-links {
        line-height: 1.8;
      }
    }
  </style>
</head>

<body>
